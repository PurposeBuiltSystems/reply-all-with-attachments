{
  "name": "reply-all-with-attachments",
  "version": "1.0.0",
  "description": "Outlook add-in that adds a one-click 'Reply All with Attachments' button to the message ribbon. Outlook normally drops the original attachments on Reply All; this restores them.",
  "private": true,
  "scripts": {
    "icons": "node tools/make-icons.js",
    "dev-certs": "office-addin-dev-certs install",
    "start": "node server.js",
    "sideload": "office-addin-debugging start manifest.xml desktop",
    "sideload:web": "office-addin-debugging start manifest.xml web",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml"
  },
  "author": "Matthew Miller",
  "license": "MIT",
  "devDependencies": {
    "office-addin-debugging": "^6.0.4",
    "office-addin-dev-certs": "^2.0.4",
    "office-addin-manifest": "^2.0.4"
  }
}
